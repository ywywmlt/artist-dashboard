# setlist.fm (https://api.setlist.fm/docs/1.0/index.html)
SETLISTFM_API_KEY=

# MusicBrainz requires a descriptive User-Agent, no API key
MUSICBRAINZ_APP_NAME=ArtistDashboard
MUSICBRAINZ_APP_VERSION=0.1
MUSICBRAINZ_CONTACT=your-email@example.com

# Ticketmaster Discovery API (https://developer.ticketmaster.com/)
TICKETMASTER_API_KEY=
